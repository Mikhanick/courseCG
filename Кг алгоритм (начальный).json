      {"id": "write_color", "label": "Запись в ColorBuffer", "type": "process", "comment": "colorData[y * width + x] := color"},
      {"id": "calc_shading", "label": "Расчет освещения", "type": "process", "comment": "NdotL, shadowFactor, maxShade"},
      {"id": "write_shade", "label": "Запись в ShadeBuffer", "type": "process", "comment": "shadeData[y * width + x] := maxShade"},
      {"id": "bbox_loop_end", "label": "Конец цикла (x,y)", "type": "loopLimitEnd"},
