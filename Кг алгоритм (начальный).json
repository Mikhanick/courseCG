      {"id": "project_vertices", "label": "Project(worldPos, x, y, z, w)", "type": "process", "comment": "Проекция с 4 параметрами"},
      {"id": "create_fragment", "label": "Создание FragmentData", "type": "process", "comment": "x, y, depth, worldPos"},
