import json
import numpy as np
from typing import List, Tuple, Dict, Any, Optional

class BuildingSection:
    """Represents a single section of a building with corrected outward normals"""
    
    def __init__(self):
        self.vertices: List[List[float]] = []
        self.faces: List[List] = []  # [v0, v1, v2, color]
        self.building_bounds = None  # Will be set after all vertices are added
    
    def add_vertex(self, x: float, y: float, z: float) -> int:
        """Add a vertex and return its index"""
        self.vertices.append([x, y, z])
        return len(self.vertices) - 1
    
    def _calculate_normal(self, p0: np.ndarray, p1: np.ndarray, p2: np.ndarray) -> np.ndarray:
        """Calculate face normal using right-hand rule"""
        edge1 = p1 - p0
        edge2 = p2 - p0
        normal = np.cross(edge1, edge2)
        length = np.linalg.norm(normal)
        return normal / length if length > 0 else normal
    
    def _get_building_bounds(self):
        """Calculate building boundaries for normal direction determination"""
        if self.building_bounds is None and self.vertices:
            vertices = np.array(self.vertices)
            self.building_bounds = {
                'min_x': np.min(vertices[:, 0]),
                'max_x': np.max(vertices[:, 0]),
                'min_y': np.min(vertices[:, 1]),
                'max_y': np.max(vertices[:, 1]),
                'min_z': np.min(vertices[:, 2]),
                'max_z': np.max(vertices[:, 2]),
            }
        return self.building_bounds
    
    def _is_normal_outward(self, normal: np.ndarray, centroid: np.ndarray) -> bool:
        """Determine if normal points outward based on position in building"""
        bounds = self._get_building_bounds()
        if bounds is None:
            return True  # Default to assuming outward if no bounds
        
        # Determine which face of the building this is closest to
        x_pos = centroid[0]
        y_pos = centroid[1]
        z_pos = centroid[2]
        
        # Tolerance for boundary detection
        tol = 0.1
        
        # Front face (Z=min) - normal should point in negative Z direction
        if abs(z_pos - bounds['min_z']) < tol:
            return normal[2] < 0
        
        # Back face (Z=max) - normal should point in positive Z direction
        if abs(z_pos - bounds['max_z']) < tol:
            return normal[2] > 0
        
        # Left face (X=min) - normal should point in negative X direction
        if abs(x_pos - bounds['min_x']) < tol:
            return normal[0] < 0
        
        # Right face (X=max) - normal should point in positive X direction
        if abs(x_pos - bounds['max_x']) < tol:
            return normal[0] > 0
        
        # Bottom face (Y=min) - normal should point in negative Y direction
        if abs(y_pos - bounds['min_y']) < tol:
            return normal[1] < 0
        
        # Top face (Y=max) - normal should point in positive Y direction
        if abs(y_pos - bounds['max_y']) < tol:
            return normal[1] > 0
        
        # For internal faces, assume outward is away from building center
        building_center = np.array([
            (bounds['min_x'] + bounds['max_x']) / 2,
            (bounds['min_y'] + bounds['max_y']) / 2,
            (bounds['min_z'] + bounds['max_z']) / 2
        ])
        
        to_center = building_center - centroid
        return np.dot(normal, to_center) < 0
    
    def _triangulate_polygon(self, vertex_indices: List[int]) -> List[List[int]]:
        """Triangulate convex polygon using fan method"""
        if len(vertex_indices) < 3:
            raise ValueError("Polygon must have at least 3 vertices")
        
        # Special handling for quads
        if len(vertex_indices) == 4:
            return self._triangulate_quad(vertex_indices)
        
        # Fan triangulation for polygons with more than 4 vertices
        triangles = []
        for i in range(1, len(vertex_indices) - 1):
            triangles.append([
                vertex_indices[0],
                vertex_indices[i],
                vertex_indices[i + 1]
            ])
        
        return triangles
    
    def _triangulate_quad(self, vertex_indices: List[int]) -> List[List[int]]:
        """Optimized triangulation for quads with proper diagonal selection"""
        v0, v1, v2, v3 = vertex_indices
        
        # Calculate both possible diagonals
        p0 = np.array(self.vertices[v0])
        p1 = np.array(self.vertices[v1])
        p2 = np.array(self.vertices[v2])
        p3 = np.array(self.vertices[v3])
        
        diag1_len = np.linalg.norm(p0 - p2)
        diag2_len = np.linalg.norm(p1 - p3)
        
        # Choose shorter diagonal for better triangulation
        if diag1_len < diag2_len:
            return [[v0, v1, v2], [v0, v2, v3]]
        else:
            return [[v0, v1, v3], [v1, v2, v3]]
    
    def _add_triangle_face(self, v0: int, v1: int, v2: int, color: str):
        """Add a triangle face with guaranteed outward-facing normal"""
        p0 = np.array(self.vertices[v0])
        p1 = np.array(self.vertices[v1])
        p2 = np.array(self.vertices[v2])
        
        normal = self._calculate_normal(p0, p1, p2)
        centroid = (p0 + p1 + p2) / 3
        
        # Check if normal points outward, reverse if needed
        if not self._is_normal_outward(normal, centroid):
            v1, v2 = v2, v1
        
        self.faces.append([v0, v1, v2, color])
    
    def add_face(self, v0: int, v1: int, v2: int, color: str):
        """Add a triangle face with automatic outward normal correction"""
        self._add_triangle_face(v0, v1, v2, color)
    
    def add_polygon(self, vertex_indices: List[int], color: str):
        """Add a polygon with automatic triangulation and outward normals"""
        if len(vertex_indices) == 3:
            self.add_face(vertex_indices[0], vertex_indices[1], vertex_indices[2], color)
            return
        
        if len(vertex_indices) < 3:
            raise ValueError("Polygon must have at least 3 vertices")
        
        # Triangulate the polygon
        triangles = self._triangulate_polygon(vertex_indices)
        
        # Add each triangle with proper normal direction
        for tri in triangles:
            self._add_triangle_face(tri[0], tri[1], tri[2], color)
    
    def add_box(
        self,
        x0: float, x1: float,
        y0: float, y1: float,
        z0: float, z1: float,
        wall_color: str,
        top_color: Optional[str] = None,
        bottom_color: Optional[str] = None
    ):
        """Add a rectangular box section with proper outward normals"""
        # Create vertices
        v = [
            self.add_vertex(x0, y0, z0),  # 0 - front-left-bottom
            self.add_vertex(x1, y0, z0),  # 1 - front-right-bottom
            self.add_vertex(x1, y0, z1),  # 2 - back-right-bottom
            self.add_vertex(x0, y0, z1),  # 3 - back-left-bottom
            self.add_vertex(x0, y1, z0),  # 4 - front-left-top
            self.add_vertex(x1, y1, z0),  # 5 - front-right-top
            self.add_vertex(x1, y1, z1),  # 6 - back-right-top
            self.add_vertex(x0, y1, z1),  # 7 - back-left-top
        ]
        
        # Add walls with explicit vertex ordering for proper normals
        self.add_polygon([v[0], v[4], v[5], v[1]], wall_color)  # Front wall (Z=z0)
        self.add_polygon([v[3], v[7], v[6], v[2]], wall_color)  # Back wall (Z=z1)
        self.add_polygon([v[0], v[3], v[7], v[4]], wall_color)  # Left wall (X=x0)
        self.add_polygon([v[1], v[5], v[6], v[2]], wall_color)  # Right wall (X=x1)
        
        if top_color:
            self.add_polygon([v[4], v[7], v[6], v[5]], top_color)  # Top face
        
        if bottom_color:
            self.add_polygon([v[0], v[1], v[2], v[3]], bottom_color)  # Bottom face
    
    def add_window(
        self,
        wall_type: str,
        win_x0: float, win_x1: float,
        win_y0: float, win_y1: float,
        win_z0: float, win_z1: float,
        frame_color: str,
        glass_color: str,
        inset_depth: float = 0.0
    ) -> int:
        """Add a window with proper outward-facing normals and optional inset"""
        # Create window vertices
        base_idx = len(self.vertices)
        
        # Front face vertices (order for outward normal)
        v0 = self.add_vertex(win_x0, win_y0, win_z0)  # bottom-left
        v1 = self.add_vertex(win_x1, win_y0, win_z0)  # bottom-right
        v2 = self.add_vertex(win_x1, win_y1, win_z0)  # top-right
        v3 = self.add_vertex(win_x0, win_y1, win_z0)  # top-left
        
        # Glass face - ensure outward normal
        self.add_polygon([v0, v3, v2, v1], glass_color)  # CCW order for front face
        
        # Handle inset depth
        if inset_depth > 0:
            if wall_type == 'front':
                z_inset = win_z0 + inset_depth
                v4 = self.add_vertex(win_x0, win_y0, z_inset)  # bottom-left inner
                v5 = self.add_vertex(win_x1, win_y0, z_inset)  # bottom-right inner
                v6 = self.add_vertex(win_x1, win_y1, z_inset)  # top-right inner
                v7 = self.add_vertex(win_x0, win_y1, z_inset)  # top-left inner
                
                # Add side faces with proper outward normals
                self.add_polygon([v0, v1, v5, v4], frame_color)  # Bottom face
                self.add_polygon([v1, v2, v6, v5], frame_color)  # Right face
                self.add_polygon([v2, v3, v7, v6], frame_color)  # Top face
                self.add_polygon([v3, v0, v4, v7], frame_color)  # Left face
            # Additional wall types can be implemented similarly
        
        return len(self.vertices)

class BuildingModel:
    """Represents a complete building model"""
    
    def __init__(
        self,
        name: str,
        description: str,
        author: str,
        version: str,
        min_width: float,
        max_width: float,
        min_depth: float,
        max_depth: float,
        floor_count: int,
        fixed_scale: bool = True,
        texture_scale: float = 1.0
    ):
        self.metadata = {
            "name": name,
            "description": description,
            "author": author,
            "version": version
        }
        self.dimensions = {
            "min_width": min_width,
            "max_width": max_width,
            "min_depth": min_depth,
            "max_depth": max_depth,
            "fixed_scale": fixed_scale
        }
        self.floors = {
            "count": floor_count,
            "texture_scale": texture_scale
        }
        self.ground_floor = BuildingSection()
        self.typical_floor = BuildingSection()
        self.roof = BuildingSection()
    
    def to_json(self) -> str:
        """Convert model to JSON string with final validation"""
        self._validate_and_finalize()
        return self._generate_json()
    
    def _validate_and_finalize(self):
        """Final validation and normalization before export"""
        # Calculate building bounds for each section
        for section in [self.ground_floor, self.typical_floor, self.roof]:
            section._get_building_bounds()
        
        # Validate vertex indices
        sections = {
            "ground_floor": self.ground_floor,
            "typical_floor": self.typical_floor,
            "roof": self.roof
        }
        
        for name, section in sections.items():
            for i, face in enumerate(section.faces):
                for idx in face[:3]:
                    if idx >= len(section.vertices):
                        raise ValueError(f"Section '{name}' face {i} references invalid vertex index {idx}")
            
            # Validate no negative coordinates
            for i, v in enumerate(section.vertices):
                if any(coord < 0 for coord in v):
                    raise ValueError(f"Section '{name}' vertex {i} has negative coordinate: {v}")
    
    def _generate_json(self) -> str:
        """Generate final JSON representation"""
        model = {
            "metadata": self.metadata,
            "dimensions": self.dimensions,
            "floors": self.floors,
            "ground_floor": {
                "vertices": self.ground_floor.vertices,
                "faces": self.ground_floor.faces
            },
            "typical_floor": {
                "vertices": self.typical_floor.vertices,
                "faces": self.typical_floor.faces
            },
            "roof": {
                "vertices": self.roof.vertices,
                "faces": self.roof.faces
            }
        }
        return json.dumps(model, indent=2)

def generate_soviet_apartment() -> str:
    """Generate Soviet apartment building with correctly oriented outward normals"""
    model = BuildingModel(
        name="apartment_soviet",
        description="Soviet-era 5-story panel building with square windows",
        author="UrbanSim3D_v3",
        version="1.4",
        min_width=25.0,
        max_width=27.0,
        min_depth=15.0,
        max_depth=16.0,
        floor_count=5,
        fixed_scale=True,
        texture_scale=1.0
    )
    
    # Building parameters
    width = 25.0
    depth = 15.0
    ground_floor_height = 5.0
    typical_floor_height = 3.5
    roof_height = 1.5
    panel_width = 5.0
    num_panels = int(width / panel_width)
    window_width = 2.0
    window_height = 2.0
    window_y_start = 1.0
    entrance_panel_index = 2
    entrance_width = 3.0
    entrance_height = 2.5
    canopy_depth = 1.0
    canopy_height = 3.0
    
    # Ground floor section
    gf = model.ground_floor
    
    # Main building volume - correct outward normals
    gf.add_box(
        x0=0, x1=width,
        y0=0, y1=ground_floor_height,
        z0=0, z1=depth,
        wall_color="#8B7D6B",
        top_color="#A9A9A9"
    )
    
    # Add entrance with proper outward normals
    entrance_x_start = entrance_panel_index * panel_width + (panel_width - entrance_width) / 2
    entrance_x_end = entrance_x_start + entrance_width
    
    # Door vertices
    v8 = gf.add_vertex(entrance_x_start, 0.0, 0.0)  # bottom-left
    v9 = gf.add_vertex(entrance_x_end, 0.0, 0.0)   # bottom-right
    v10 = gf.add_vertex(entrance_x_start, entrance_height, 0.0)  # top-left
    v11 = gf.add_vertex(entrance_x_end, entrance_height, 0.0)    # top-right
    
    # Canopy vertices
    v12 = gf.add_vertex(entrance_x_start, canopy_height, canopy_depth)  # top-left-back
    v13 = gf.add_vertex(entrance_x_end, canopy_height, canopy_depth)   # top-right-back
    v14 = gf.add_vertex(entrance_x_start, ground_floor_height, canopy_depth)  # bottom-left-back
    v15 = gf.add_vertex(entrance_x_end, ground_floor_height, canopy_depth)   # bottom-right-back
    
    # Door face - outward normal (front face)
    gf.add_polygon([v8, v10, v11, v9], "#8B4513")  # CCW order when viewed from outside
    
    # Canopy faces with proper outward normals
    gf.add_polygon([v10, v11, v13, v12], "#A9A9A9")  # Front face
    gf.add_polygon([v11, v9, v15, v13], "#A9A9A9")   # Right face
    gf.add_polygon([v9, v8, v14, v15], "#A9A9A9")    # Bottom face
    gf.add_polygon([v8, v10, v12, v14], "#8B7D6B")   # Left face
    gf.add_polygon([v12, v13, v15, v14], "#A9A9A9")  # Top face
    
    # Typical floor section
    tf = model.typical_floor
    
    # Base box with proper outward normals
    tf.add_box(
        x0=0, x1=width,
        y0=0, y1=typical_floor_height,
        z0=0, z1=depth,
        wall_color="#8B7D6B",
        top_color="#A9A9A9"
    )
    
    # Add windows with proper normals
    for i in range(num_panels):
        x0 = i * panel_width
        win_x_start = x0 + (panel_width - window_width) / 2
        win_x_end = win_x_start + window_width
        
        tf.add_window(
            wall_type='front',
            win_x0=win_x_start,
            win_x1=win_x_end,
            win_y0=window_y_start,
            win_y1=window_y_start + window_height,
            win_z0=0.0,
            win_z1=0.0,
            frame_color="#8B7D6B",
            glass_color="#B0C4DE",
            inset_depth=0.2
        )
    
    # Roof section (pyramidal) with outward normals
    rf = model.roof
    
    # Base vertices
    v0 = rf.add_vertex(0, 0, 0)           # front-left
    v1 = rf.add_vertex(width, 0, 0)       # front-right
    v2 = rf.add_vertex(width, 0, depth)   # back-right
    v3 = rf.add_vertex(0, 0, depth)       # back-left
    
    # Peak vertex
    v4 = rf.add_vertex(width/2, roof_height, depth/2)  # peak
    
    # Roof faces with outward normals (pointing up and out)
    rf.add_polygon([v0, v1, v4], "#A9A9A9")  # Front face
    rf.add_polygon([v1, v2, v4], "#A9A9A9")  # Right face
    rf.add_polygon([v2, v3, v4], "#A9A9A9")  # Back face
    rf.add_polygon([v3, v0, v4], "#A9A9A9")  # Left face
    
    return model.to_json()

if __name__ == "__main__":
    print(generate_soviet_apartment())